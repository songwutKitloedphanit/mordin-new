+  flex-shrink: 0;
+  width: 56px;
+  height: 56px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-radius: 50%;
+  font-size: 1.6rem;
+}
+
+.exec-brief-tile-body {
+  min-width: 0;
+}
+
+.exec-brief-tile-label {
+  font-size: 1.05rem;
+  font-weight: 600;
+  color: #667085;
+  margin-bottom: 2px;
+}
+
+.exec-brief-tile-value {
+  font-size: 1.7rem;
+  font-weight: 700;
+  line-height: 1.2;
+  color: #1f2733;
+  word-break: break-word;
+}
+
+.exec-brief-tile-sub {
+  font-size: 1.05rem;
+  color: #475467;
+  margin-top: 2px;
+}
+
+.exec-brief-tile-empty {
+  font-size: 1.2rem;
+  color: #98a2b3;
+  padding: 6px 0;
+}
+
+/* ===================== ตัวกรองยุบได้ ===================== */
+.exec-filter-toggle {
+  width: 100%;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  background: transparent;
+  border: none;
+  cursor: pointer;
+  text-align: start;
+}
+
+.exec-filter-toggle:hover {
+  background: rgba(21, 114, 232, 0.04);
+}
+
+/* ===================== Tabbed Explorer ===================== */
+.exec-tabs-nav {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  margin-bottom: 16px;
+}
+
+.exec-tab-btn {
+  display: inline-flex;
+  align-items: center;
+  padding: 10px 20px;
+  border-radius: 10px;
+  border: 1px solid #e3e8ef;
+  background: #fff;
+  color: #475467;
+  font-size: 1.2rem;
+  font-weight: 600;
+  cursor: pointer;
+  transition: all 0.15s ease;
+}
+
+.exec-tab-btn:hover {
+  border-color: #1572e8;
+  color: #1572e8;
+}
+
+.exec-tab-btn.is-active {
+  background: #1572e8;
+  border-color: #1572e8;
+  color: #fff;
+  box-shadow: 0 4px 12px rgba(21, 114, 232, 0.25);
+}
+
+.exec-tab-count {
+  margin-inline-start: 8px;
+  min-width: 24px;
+  padding: 0 7px;
+  border-radius: 999px;
+  background: rgba(102, 112, 133, 0.16);
+  font-size: 0.95rem;
+  line-height: 22px;
+  text-align: center;
+}
+
+.exec-tab-btn.is-active .exec-tab-count {
+  background: rgba(255, 255, 255, 0.28);
+}
+
+/* แผงที่ไม่ active: ยุบด้วย max-height (คงความกว้างเต็มไว้ ทำให้กราฟไม่เพี้ยน) */
+.exec-tab-panel.is-inactive {
+  max-height: 0;
+  overflow: hidden;
+  opacity: 0;
+  pointer-events: none;
+}
+
+/* ----- dark mode ----- */
+.private-layout-dark main .exec-brief-caption,
+.private-layout-dark main .exec-brief-sublabel {
+  color: #9aa7b8;
+}
+
+.private-layout-dark main .exec-brief-chip {
+  background: #1c2c40;
+  border-color: #28415f;
+  color: #d7e3f0;
+}
+
+.private-layout-dark main .exec-brief-chip-label {
+  color: #7ec8f5;
+}
+
+.private-layout-dark main .exec-brief-tile {
+  background: #16202e;
+  border-color: #243446;
+  box-shadow: none;
+}
+
+.private-layout-dark main .exec-brief-tile-value {
+  color: #eef4fb;
+}
+
+.private-layout-dark main .exec-brief-tile-label,
+.private-layout-dark main .exec-brief-tile-sub {
+  color: #9aa7b8;
+}
+
+.private-layout-dark main .exec-tab-btn {
+  background: #16202e;
+  border-color: #243446;
+  color: #b7c2d0;
+}
+
+.private-layout-dark main .exec-tab-btn.is-active {
+  background: #1572e8;
+  border-color: #1572e8;
+  color: #fff;
+}
+
