# ============================================================
# mordin-backend — ตัวอย่าง environment variables (mock)
# คัดลอกค่าเหล่านี้ไปใส่ใน Render → Service → Environment
# อย่า commit ค่าจริง (.env ถูก ignore อยู่แล้ว)
# สร้าง secret จริง: openssl rand -hex 32
# ============================================================

# ----- App -----
# Render กำหนด PORT ให้อัตโนมัติ (อย่า hardcode บน Render)
# โค้ดใช้ process.env.PORT ?? 3000 และ listen ที่ 0.0.0.0 อยู่แล้ว
PORT=3000

# ----- Database (Postgres) — ใช้ DB เดียวกันทั้ง main และ logs (mock) -----
# บน Render ใช้ host จาก "Internal Database URL"
POSTGRES_HOST=dpg-xxxxxxxxxxxx-a.oregon-postgres.render.com
POSTGRES_PORT=5432
POSTGRES_USER=mordin_user
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=mordin
# Render managed Postgres ต้องใช้ SSL → ตั้งเป็น true
POSTGRES_SSL=true

# logs/audit — ชี้ DB เดียวกับด้านบน (mock)
POSTGRES_LOGS_HOST=dpg-xxxxxxxxxxxx-a.oregon-postgres.render.com
POSTGRES_LOGS_PORT=5432
POSTGRES_LOGS_USER=mordin_user
POSTGRES_LOGS_PASSWORD=CHANGE_ME_db_password
POSTGRES_LOGS_DB=mordin
POSTGRES_LOGS_SSL=true

# ----- Secrets -----
QR_SECRET=CHANGE_ME_qr_secret_hex32
JWT_ACCESS_SECRET=CHANGE_ME_jwt_access_secret_hex32
# รูปแบบ expiresIn ของ @nestjs/jwt เช่น 15m, 1h, 1d, 7d
JWT_ACCESS_EXPIRATION=1d

# ----- Azure AD / APIM (login เจ้าหน้าที่ ฝั่ง internal) -----
AZURE_AD_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
CLIENT_ID=CHANGE_ME_client_id
CLIENT_SECRET=CHANGE_ME_client_secret
APIM_SUBSCRIPTION_KEY=CHANGE_ME_apim_subscription_key
SCOPE=api://CHANGE_ME/.default
API_AUTHEN_PROFILE_URL=https://apim.example.com/authen/profile

# ----- (ถ้า merge PR #201 public farmer login เพิ่มสองตัวนี้) -----
# PUBLIC_JWT_ACCESS_SECRET=CHANGE_ME_public_jwt_secret_hex32
# PUBLIC_JWT_ACCESS_EXPIRATION=1d
